{
    "name": "laradisco-client",
    "version": "1.0.0",
    "description": "LaRADisco Desktop Client",
    "private": true,
    "type": "module",
    "main": "out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "postinstall": "electron-builder install-app-deps",
        "build:unpack": "npm run build && electron-builder --dir",
        "build:win": "npm run build && electron-builder --win",
        "build:mac": "npm run build && electron-builder --mac",
        "build:linux": "npm run build && electron-builder --linux",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "lint": "eslint . --fix",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
        "typecheck:renderer": "vue-tsc --noEmit -p tsconfig.renderer.json",
        "typecheck": "npm run typecheck:node && npm run typecheck:renderer"
    },
    "devDependencies": {
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@eslint/js": "^9.19.0",
        "@tailwindcss/vite": "^4.1.11",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^22.13.5",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/eslint-config-typescript": "^14.3.0",
        "electron": "^35.0.1",
        "electron-builder": "^26.0.12",
        "electron-vite": "^5.0.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^9.32.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.23.0",
        "vite": "^7.0.4",
        "vue-tsc": "^2.2.4"
    },
    "dependencies": {
        "@electron-toolkit/preload": "^3.0.1",
        "@electron-toolkit/utils": "^4.0.0",
        "@primeuix/themes": "^2.0.3",
        "@vueuse/core": "^12.8.2",
        "axios": "^1.13.5",
        "better-sqlite3": "^12.6.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "laravel-echo": "^2.3.0",
        "livekit-client": "^2.17.2",
        "lucide-vue-next": "^0.468.0",
        "pinia": "^3.0.4",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.4",
        "pusher-js": "^8.4.0",
        "reka-ui": "^2.6.1",
        "tailwind-merge": "^3.2.0",
        "tailwindcss": "^4.1.1",
        "tw-animate-css": "^1.2.5",
        "vue": "^3.5.13",
        "vue-input-otp": "^0.3.2",
        "vue-router": "^4.5.1",
        "vue3-emoji-picker": "^1.1.8"
    },
    "build": {
        "appId": "com.laradisco.client",
        "productName": "LaRADisco",
        "directories": {
            "buildResources": "build"
        },
        "files": [
            "out/**/*"
        ],
        "extraResources": [],
        "nodeGypRebuild": false,
        "npmRebuild": true,
        "mac": {
            "artifactName": "${productName}-${version}-${arch}.${ext}",
            "target": [
                "dmg",
                "zip"
            ]
        },
        "win": {
            "target": [
                "nsis",
                "zip"
            ]
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Network"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
