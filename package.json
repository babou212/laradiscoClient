{
    "name": "@babou212/laradisco-client",
    "version": "1.0.0",
    "description": "LaraDisco Desktop Client",
    "private": false,
    "type": "module",
    "main": "out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "dev:user2": "USER_DATA_DIR=/tmp/laradisco-user2 ELECTRON_RENDERER_URL=http://localhost:5173 npx electron .",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "package": "npm run build && electron-forge package",
        "make": "npm run build && electron-forge make",
        "make:win": "npm run build && electron-forge make --platform win32",
        "make:mac": "npm run build && electron-forge make --platform darwin",
        "make:linux": "npm run build && electron-forge make --platform linux",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "lint": "eslint . --fix",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
        "typecheck:renderer": "vue-tsc --noEmit -p tsconfig.renderer.json",
        "typecheck": "npm run typecheck:node && npm run typecheck:renderer"
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/maker-deb": "^7.11.1",
        "@electron-forge/maker-dmg": "^7.11.1",
        "@electron-forge/maker-flatpak": "^7.11.1",
        "@electron-forge/maker-squirrel": "^7.11.1",
        "@electron-forge/maker-zip": "^7.11.1",
        "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@eslint/js": "^9.19.0",
        "@tailwindcss/vite": "^4.1.11",
        "@types/better-sqlite3": "^7.6.13",
        "@types/dompurify": "^3.0.5",
        "@types/node": "^22.13.5",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/eslint-config-typescript": "^14.3.0",
        "electron": "^35.0.1",
        "electron-vite": "^5.0.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^9.32.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.23.0",
        "vite": "^7.0.4",
        "vue-tsc": "^2.2.4"
    },
    "dependencies": {
        "@electron-toolkit/preload": "^3.0.1",
        "@electron-toolkit/utils": "^4.0.0",
        "@noble/curves": "^2.0.1",
        "@noble/hashes": "^2.0.1",
        "@primeuix/themes": "^2.0.3",
        "@vueuse/core": "^12.8.2",
        "axios": "^1.13.5",
        "better-sqlite3": "^12.6.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "dompurify": "^3.3.1",
        "hash-wasm": "^4.12.0",
        "laravel-echo": "^2.3.0",
        "livekit-client": "^2.17.2",
        "lucide-vue-next": "^0.468.0",
        "pinia": "^3.0.4",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.4",
        "pusher-js": "^8.4.0",
        "reka-ui": "^2.6.1",
        "tailwind-merge": "^3.2.0",
        "tailwindcss": "^4.1.1",
        "tw-animate-css": "^1.2.5",
        "uiohook-napi": "^1.5.4",
        "vue": "^3.5.13",
        "vue-input-otp": "^0.3.2",
        "vue-router": "^4.5.1",
        "vue3-emoji-picker": "^1.1.8"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/babou212/laradiscoClient.git"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "config": {
        "forge": "./forge.config.ts"
    }
}
