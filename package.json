{
    "name": "@babou212/laradisco-client",
    "version": "1.0.14",
    "description": "LaraDisco Desktop Client",
    "author": "Dylan Cree",
    "private": false,
    "type": "module",
    "main": "out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "dev:user2": "electron-vite build --config electron.vite.config.dev2.ts && USER_DATA_DIR=/tmp/laradisco-user2 ELECTRON_RENDERER_URL=http://localhost:5173 ./node_modules/.bin/electron out2/main/index.js",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "package": "npm run build && electron-builder --dir",
        "make": "npm run build && electron-builder",
        "make:win": "npm run build && electron-builder --win --publish never",
        "make:mac": "npm run build && electron-builder --mac --publish never",
        "make:linux": "npm run build && electron-builder --linux --publish never",
        "publish": "npm run build && electron-builder --publish always",
        "publish:win": "npm run build && electron-builder --win --publish always",
        "publish:mac": "npm run build && electron-builder --mac --publish always",
        "publish:linux": "npm run build && electron-builder --linux --publish always",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "lint": "eslint . --fix",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
        "typecheck:renderer": "vue-tsc --noEmit -p tsconfig.renderer.json",
        "typecheck": "npm run typecheck:node && npm run typecheck:renderer",
        "clean:db": "rm -f \"$HOME/.config/@babou212/laradisco-client/laradisco.db\"* /tmp/laradisco-user2/laradisco.db*"
    },
    "devDependencies": {
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@eslint/js": "^9.39.4",
        "@pinia/colada-devtools": "^0.4.5",
        "@tailwindcss/vite": "^4.2.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/dompurify": "^3.0.5",
        "@types/howler": "^2.2.12",
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^22.19.17",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/eslint-config-typescript": "^14.3.0",
        "drizzle-kit": "^0.31.10",
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^9.33.0",
        "prettier": "^3.8.2",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.1",
        "vite": "^7.3.2",
        "vue-tsc": "^2.2.12"
    },
    "dependencies": {
        "@electron-toolkit/preload": "^3.0.1",
        "@electron-toolkit/utils": "^4.0.0",
        "@noble/curves": "^2.0.1",
        "@noble/hashes": "^2.0.1",
        "@pinia/colada": "^1.1.0",
        "@primeuix/themes": "^2.0.3",
        "@vueuse/core": "^12.8.2",
        "axios": "^1.15.0",
        "better-sqlite3": "^12.8.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "dompurify": "^3.3.3",
        "drizzle-orm": "^0.45.2",
        "electron-updater": "^6.8.3",
        "hash-wasm": "^4.12.0",
        "highlight.js": "^11.11.1",
        "howler": "^2.2.4",
        "ipaddr.js": "^2.3.0",
        "laravel-echo": "^2.3.4",
        "livekit-client": "^2.18.1",
        "lucide-vue-next": "^0.468.0",
        "markdown-it": "^14.1.1",
        "pinia": "^3.0.4",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "pusher-js": "^8.5.0",
        "reka-ui": "^2.9.5",
        "sharp": "^0.34.5",
        "tailwind-merge": "^3.2.0",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.2.5",
        "uiohook-napi": "^1.5.5",
        "vue": "^3.5.32",
        "vue-advanced-cropper": "^2.8.9",
        "vue-input-otp": "^0.3.2",
        "vue-router": "^4.6.4",
        "vue3-emoji-picker": "^1.1.8",
        "zod": "^4.3.6"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/babou212/laradiscoClient.git"
    }
}
